# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules

# ── Build output ──────────────────────────────────────────────────────────────
dist
dist-ssr

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
# *.local covers .env.local, vite.config.local, etc.
*.local

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local CLI state: contains DB connection strings and version pins, not for VCS
supabase/.temp

# ── Personal files ────────────────────────────────────────────────────────────
learning-roadmap.html

# ── SQL files ─────────────────────────────────────────────────────────────────
# Ignore all SQL files (backups, dumps, exports) — may contain sensitive data
*.sql
# Keep migration files: they are the source of truth for the database schema
!supabase/migrations/*.sql

# ── Claude Code ───────────────────────────────────────────────────────────────
# Machine-specific permission settings — not for VCS
.claude/settings.local.json

# ── Logs ──────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / editor artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── VSCode ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
