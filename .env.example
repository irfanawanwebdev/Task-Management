# JZ Smart Media — Operations Hub
# Environment Variables
#
# Copy this file to .env.local and fill in your Supabase project values.
# NEVER commit .env.local to version control.

# ── Supabase ─────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Jobs Companion Service (Phase 5) ────────────────────────────────────
# URL of the Node.js service hosting Trigger.dev + Puppeteer
# VITE_JOBS_SERVICE_URL=https://your-jobs-service.railway.app
